# ==============================================
# wzap Application Configuration
# ==============================================

# Application
PORT=8080
SERVER_HOST=0.0.0.0
API_KEY=your-api-key-here
LOG_LEVEL=info
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/wzap?sslmode=disable
POSTGRES_DB=wzap
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-db-password
POSTGRES_PORT=5432

# Storage (MinIO)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=wzap-media
MINIO_USE_SSL=false

# Queue (NATS)
NATS_URL=nats://localhost:4222

# WhatsApp
WA_LOG_LEVEL=INFO

# Webhooks
GLOBAL_WEBHOOK_URL=https://your-domain.com/webhooks
