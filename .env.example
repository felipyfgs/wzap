# ==============================================
# wzap Application Configuration
# ==============================================

# Application
PORT=8080
SERVER_HOST=0.0.0.0
ADMIN_TOKEN=wzap-dev-key
LOG_LEVEL=debug
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgres://wzap:wzap123@localhost:5435/wzap?sslmode=disable
POSTGRES_DB=wzap
POSTGRES_USER=wzap
POSTGRES_PASSWORD=wzap123
POSTGRES_PORT=5435

# Storage (MinIO)
MINIO_ENDPOINT=localhost:9010
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123
MINIO_BUCKET=wzap-media
MINIO_USE_SSL=false

# Queue (NATS)
NATS_URL=nats://localhost:4222

# WhatsApp
WA_LOG_LEVEL=INFO

# Webhooks
GLOBAL_WEBHOOK_URL=
