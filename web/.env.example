# =============================================================================
# wzap-web — variáveis de ambiente do frontend Nuxt
# =============================================================================
# Nota: quando rodando via docker-compose, estas variáveis são sobrescritas
# pelos overlays (docker-compose.dev.yml / docker-compose.prod.yml).
# =============================================================================

# URL da API Go do wzap (usada pelo proxy Nitro em server/api/[...].ts)
NUXT_API_URL=http://localhost:8080

# Endpoint do MinIO (usado por server/api/media-proxy.get.ts p/ whitelist SSRF)
NUXT_MINIO_ENDPOINT=http://localhost:9010

# URL pública do site (usada para OG Image em nuxt generate)
NUXT_PUBLIC_SITE_URL=
